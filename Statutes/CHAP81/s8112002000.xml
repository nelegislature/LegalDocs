<law type="statute"><section id="id432"><amendatorysection amended="yes" chaptername="State Administrative Departments" id="id16" statutenumber="81-1202"><bookinfo>Revised Statutes Cumulative Supplement, 2026</bookinfo><statuteno>81-1202</statuteno><catchline id="id19">Job training grant, defined.</catchline><para>For purposes of sections 81-1202 to 81-1210, job training grant means a grant from any nonfederal funding source within the Department of Economic Development awarded by the department.</para></amendatorysection></section><source><para>Laws 1995, LB 326, &#167; 1; </para><para>Laws 2008, LB956, &#167; 2; </para><para>Laws 2026, LB1072, &#167; 185. </para><operativedate>December 31, 2026</operativedate></source></law>
